---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FooterMenu from '../components/FooterMenu.astro';
import FormattedDate from '../components/FormattedDate.astro';
import HeaderArticle from "../components/HeaderArticle.astro";
import { getPopularPosts } from '../lib/getPopularPosts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, latestPosts } = Astro.props;

const categoryMap: Record<string, string> = {
  "campsite": "キャンプ場",
  "campgear": "キャンプギア",
  "outdoor": "アウトドア",
  "miscellaneous": "雑記",
  "gourmet": "グルメ",
};

const displayCategory = categoryMap[category] || category;
const popular = (await getPopularPosts()).slice(0, 5);

const formatDate = (date) => {
  const d = new Date(date);
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
};
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <HeaderArticle />
    <main class="article-layout">
      <div class="main-column">
        <section class="article-hero">
          <h1 class="title">{title}</h1>
          <div class="hero-meta-row">
            <p class="category">{displayCategory}</p>
            <div class="meta">
              <span><i class="fa-regular fa-clock"></i> {formatDate(pubDate)}</span>
              {updatedDate && <span><i class="fa-solid fa-arrows-rotate"></i> {formatDate(updatedDate)}</span>}
            </div>
          </div>
          {heroImage && <img src={heroImage.src} alt={title} class="hero-image" />}
        </section>

        <nav class="toc-main">
          <h3 class="toc-main-title">目次</h3>
          <div class="toc-main-container" id="tocMainContainer">
            <ul>
              {(() => {
                let h2Count = 0; let h3Count = 0;
                return Astro.props.headings.map(h => {
                  if (h.depth === 2) {
                    h2Count++; h3Count = 0;
                    return <li class="toc-main-level-2"><a href={`#${h.slug}`}>{h2Count}｜ {h.text}</a></li>;
                  }
                  if (h.depth === 3) {
                    h3Count++;
                    return <li class="toc-main-level-3"><a href={`#${h.slug}`}>{h2Count}-{h3Count}｜ {h.text}</a></li>;
                  }
                  return null;
                });
              })()}
            </ul>
          </div>
          <button class="toc-main-toggle" id="tocMainToggle">もっと見る</button>
        </nav>

        <article class="main-post-content">
          <slot />
        </article>
      </div>

      <aside class="sidebar">
        <section class="sidebar-block latest-cards" aria-label="新着記事">
          <h3 class="sidebar-title">新着記事</h3>
          <ul class="latest-cards-list">
            {latestPosts.map(post => (
              <li class="card">
                <a class="card-link" href={`/${post.id}`}>
                  <div class="card-thumb">
                    {post.data.heroImage ? <Image src={post.data.heroImage} alt={post.data.title} class="thumb-img" width={100} height={60} /> : <div class="thumb-fallback">No Image</div>}
                  </div>
                  <div class="card-body">
                    <div class="card-title">{post.data.title}</div>
                    <div class="card-meta"><i class="fa-regular fa-clock"></i> {formatDate(post.data.pubDate)}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="sidebar-block latest-cards" aria-label="人気記事">
          <h3 class="sidebar-title">人気記事</h3>
          <ul class="latest-cards-list">
            {popular.map(post => (
              <li class="card">
                <a class="card-link" href={`/${post.astro.id}`}>
                  <div class="card-thumb">
                    {post.astro.data.heroImage ? <Image src={post.astro.data.heroImage} alt={post.astro.data.title} class="thumb-img" width={100} height={60} /> : <div class="thumb-fallback">No Image</div>}
                  </div>
                  <div class="card-body">
                    <div class="card-title">{post.astro.data.title}</div>
                    <div class="card-meta"><i class="fa-regular fa-clock"></i> {formatDate(post.astro.data.pubDate)} <span class="pv-count">{post.pageviews} PV</span></div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="sidebar-block toc-sticky">
          <h3 class="sidebar-title">目次</h3>
          <div class="toc-side-container">
            <nav class="toc-side">
              <ul>
                {(() => {
                  let h2Count = 0; let h3Count = 0;
                  return Astro.props.headings.map(h => {
                    if (h.depth === 2) {
                      h2Count++; h3Count = 0;
                      return <li class="toc-side-level-2"><a href={`#${h.slug}`}>{h2Count}｜ {h.text}</a></li>;
                    }
                    if (h.depth === 3) {
                      h3Count++;
                      return <li class="toc-side-level-3"><a href={`#${h.slug}`}>{h2Count}-{h3Count}｜ {h.text}</a></li>;
                    }
                    return null;
                  });
                })()}
              </ul>
            </nav>
          </div>
          <div class="toc-side-ad"><div class="ad-box">広告スペース</div></div>
        </section>
      </aside>
    </main>

    <div id="mobileTocOverlay" class="mobile-toc-overlay" aria-hidden="true">
      <div class="mobile-toc-content">
        <div class="mobile-toc-header">
          <span>目次</span>
          <button id="closeToc" type="button">✕</button>
        </div>
        <nav class="mobile-toc-body">
          <ul>
            {(() => {
              let h2Count = 0; let h3Count = 0;
              return Astro.props.headings.map(h => {
                if (h.depth === 2) {
                  h2Count++; h3Count = 0;
                  return <li class="m-toc-l2"><a href={`#${h.slug}`} class="m-toc-link">{h2Count}｜ {h.text}</a></li>;
                }
                if (h.depth === 3) {
                  h3Count++;
                  return <li class="m-toc-l3"><a href={`#${h.slug}`} class="m-toc-link">{h2Count}-{h3Count}｜ {h.text}</a></li>;
                }
                return null;
              });
            })()}
          </ul>
        </nav>
      </div>
    </div>

    <Footer />
    <FooterMenu />

    <script is:inline>
      function initAllTocFeatures() {
        const tocMainContainer = document.getElementById("tocMainContainer");
        const tocMainToggle = document.getElementById("tocMainToggle");
        if (tocMainToggle && tocMainContainer) {
          tocMainToggle.onclick = () => {
            tocMainContainer.classList.toggle("expanded");
            tocMainToggle.textContent = tocMainContainer.classList.contains("expanded") ? "閉じる" : "もっと見る";
          };
        }

        const overlay = document.getElementById('mobileTocOverlay');
        const closeBtn = document.getElementById('closeToc');
        const links = document.querySelectorAll('.m-toc-link');
        const footerBtns = document.querySelectorAll('.mobile-footer-menu button');
        const tocBtn = Array.from(footerBtns).find(btn => btn.innerText.includes('目次'));

        if (!overlay) return;

        const open = (e) => {
          if (e) e.preventDefault();
          overlay.style.display = 'block';
          document.body.style.overflow = 'hidden';
          setTimeout(() => overlay.classList.add('is-active'), 10);
        };
        const close = () => {
          overlay.classList.remove('is-active');
          document.body.style.overflow = '';
          setTimeout(() => { overlay.style.display = 'none'; }, 300);
        };

        tocBtn?.addEventListener('click', open);
        closeBtn?.addEventListener('click', close);
        links.forEach(link => link.addEventListener('click', close));
        overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
      }
      initAllTocFeatures();
      document.addEventListener('astro:page-load', initAllTocFeatures);
    </script>
  </body>
</html>

<style>
  /* --- 共通リセット設定 --- */
  * { box-sizing: border-box; }
  
  /* --- 全体レイアウト --- */
  .article-layout {
    display: flex;
    gap: 2rem;
    padding: 150px 1rem 0; /* PCでも最低限の左右余白を確保 */
    max-width: 1200px;
    margin: 0 auto;
  }
  .main-column { flex: 1; max-width: 850px; min-width: 0; }
  .sidebar { flex: 0 0 300px; min-width: 300px; }

  /* --- サイドバー関連 --- */
  .sidebar-block { margin-bottom: 2rem; }
  .sidebar-title {
    font-size: 1.1rem; font-weight: 600; background: #e9f4e9;
    padding: 8px 12px; border-radius: 6px; color: #2f5d3a;
    margin-bottom: 1rem; border-left: 4px solid #4a7c59;
  }
  .latest-cards-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem; }
  .card { background: #fff; border: 1px solid #eee; border-radius: 4px; overflow: hidden; }
  .card-link { display: flex; gap: 0.75rem; text-decoration: none; color: inherit; padding: 0.5rem; }
  .card-thumb { width: 100px; height: 60px; overflow: hidden; background: #f2f2f2; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .thumb-img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 4px; }
  .card-body { display: flex; flex-direction: column; justify-content: space-between; min-width: 0; flex: 1; }
  .card-title { font-size: 0.8rem; font-weight: 570; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .card-meta { font-size: 0.65rem; color: #666; margin-top: 4px; }

  /* --- 本文内TOC --- */
  .toc-main { max-width: 700px; margin: 0 auto 2rem auto; background: #fff; border: 1px solid #e5e5e5; padding: 1.2rem; border-radius: 8px; }
  .toc-main-title { font-size: 1.2rem; font-weight: 600; margin-bottom: 1rem; text-align: center; color: #333; }
  .toc-main-container { max-height: 220px; overflow: hidden; transition: max-height 0.3s ease; }
  .toc-main-container.expanded { max-height: 2000px; }
  .toc-main ul { list-style: none; padding: 0; margin: 0; }
  .toc-main-level-2 { margin: 0.5rem 0; font-weight: 500; }
  .toc-main-level-3 { margin-left: 1.2rem; font-size: 0.9rem; margin-bottom: 0.3rem; }
  .toc-main a { text-decoration: none; color: #333; }
  .toc-main-toggle { margin-top: 1rem; background: #f2f2f2; border: none; padding: 8px; border-radius: 4px; cursor: pointer; width: 100%; font-size: 0.9rem; }

  /* --- サイドバー追従TOC --- */
  .toc-sticky { position: sticky; top: 10px; z-index: 10; }
  .toc-side-container { max-height: 400px; overflow-y: auto; padding-right: 6px; }
  .toc-side { background: #f8f8f8; padding: 1rem; border-radius: 8px; }
  .toc-side ul { list-style: none; padding: 0; }
  .toc-side a { color: #333; text-decoration: none; font-size: 0.85rem; display: block; padding: 2px 0; }
  .toc-side-level-3 { margin-left: 1rem; font-size: 0.8rem; color: #666; }

  /* --- ヒーローセクション --- */
  .article-hero .title { font-size: 1.5rem; line-height: 1.3; }
  .hero-meta-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .category { background: #e9f4e9; color: #2f5d3a; padding: 4px 10px; border-radius: 4px; border-left: 3px solid #4a7c59; font-size: 0.85rem; margin: 0; }
  .meta { display: flex; gap: 0.75rem; font-size: 0.85rem; color: #666; }
  .hero-image { width: 100%; height: auto; border-radius: 8px; margin-top: 1rem; display: block; }

  /* --- モバイルオーバーレイ --- */
.mobile-toc-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 100000 !important;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.mobile-toc-overlay.is-active {
  opacity: 1;
}

/* 目次本体：ここが「にょきっと」動く */
.mobile-toc-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 20px 20px 0 0;
  
  /* 最初は画面の下に完全に隠しておく */
  transform: translateY(100%);
  
  /* 0.4秒かけて、少し弾むような滑らかな動きで上がってくる */
  transition: transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  
  display: flex;
  flex-direction: column;
  box-shadow: 0 -5px 20px rgba(0,0,0,0.2);
}
  .mobile-toc-overlay.is-active .mobile-toc-content { transform: translateY(0); }
  .mobile-toc-header { padding: 1.2rem 1.5rem; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; font-weight: bold; color: #2f5d3a; }
  #closeToc { background: #f0f0f0; border: none; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; }
  .mobile-toc-body { padding: 1rem 1.5rem 2.5rem; overflow-y: auto; -webkit-overflow-scrolling: touch; }
  .mobile-toc-body ul { list-style: none; padding: 0; }
  .mobile-toc-body li { margin-bottom: 1rem; border-bottom: 1px solid #f9f9f9; padding-bottom: 0.5rem; }
  .m-toc-link { text-decoration: none; color: #333; display: block; font-size: 0.95rem; }
  .m-toc-l3 { padding-left: 1.2rem; }
  .m-toc-l3 .m-toc-link { color: #666; font-size: 0.85rem; }

  /* --- モバイルレスポンシブ --- */
  @media (max-width: 970px) {
    .sidebar { display: none; }
    .article-layout { padding-top: 100px; padding-left: 0; padding-right: 0; width: 100%; }
    .main-column { padding: 0 1rem; width: 100%; }
    .article-hero .title { font-size: 1.25rem; font-weight: 700; }
    .meta { font-size: 0.75rem; }
    .category { font-size: 0.75rem; }
  }
  
  /* PC用表示リセット */
  @media (min-width: 971px) {
    .mobile-toc-overlay { display: none !important; }
  }
</style>