---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import HeaderArticle from '../../components/HeaderArticle.astro';
import Footer from '../../components/Footer.astro';
import FooterMenu from '../../components/FooterMenu.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  const pathConfigs = {
    "outdoor": ["outdoor", "campsite", "campgear"],
    "miscellaneous": ["miscellaneous", "gourmet", "travel"],
    "campsite": ["campsite"],
    "campgear": ["campgear"],
    "gourmet": ["gourmet"],
    "travel": ["travel"],
  };

  return Object.entries(pathConfigs).map(([slug, categoryList]) => {
    const filteredPosts = allPosts
      .filter((post) => {
        const cat = post.data.category;
        const catString = (typeof cat === 'object' && cat !== null) 
          ? (cat as any).id || cat.toString() 
          : cat;
        return categoryList.includes(catString);
      })
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { category: slug },
      props: { posts: filteredPosts },
    };
  });
}

const { category } = Astro.params;
const { posts } = Astro.props;

const categoryMap: Record<string, string> = {
  "outdoor": "アウトドア一覧",
  "miscellaneous": "雑記一覧",
  "campsite": "キャンプ場",
  "campgear": "キャンプギア",
  "gourmet": "グルメ情報",
  "travel": "トラベル情報",
};

const subCategoryMap: Record<string, string> = {
  "campsite": "キャンプ場",
  "campgear": "キャンプギア",
  "outdoor": "アウトドア",
  "miscellaneous": "雑記",
  "gourmet": "グルメ",
  "travel": "旅行",
};

const displayCategory = categoryMap[category] || category;
---

<html lang="ja">
  <head>
    <BaseHead title={`${displayCategory}の記事一覧`} description={`${displayCategory}に関する記事をまとめたページです。`} />
  </head>
  <body>
    <HeaderArticle />

    <main class="category-container">
      <header class="category-header">
        <span class="label">Category</span>
        <h1>{displayCategory}</h1>
        <p>{posts.length} 件の記事があります</p>
      </header>

      <div class="post-grid">
        {posts.map((post) => {
          const rawCat = post.data.category;
          const catStr = (typeof rawCat === 'object' && rawCat !== null) ? (rawCat as any).id || rawCat.toString() : rawCat;
          const subCatName = subCategoryMap[catStr] || catStr;

          return (
            <a href={`/${post.id}/`} class="post-card">
              <div class="card-thumb-wrap">
                {post.data.heroImage ? (
                  <img src={post.data.heroImage.src} alt="" />
                ) : (
                  <div class="no-image">No Image</div>
                )}
                <span class="card-badge">{subCatName}</span>
              </div>
              <div class="post-info">
                <time><i class="fa-regular fa-clock"></i> {post.data.pubDate.toLocaleDateString('ja-JP')}</time>
                <h2>{post.data.title}</h2>
              </div>
            </a>
          );
        })}
      </div>
    </main>

    <Footer />
    <FooterMenu />
  </body>
</html>

<style>
  /* --- 全体のはみ出し防止 --- */
  * {
    box-sizing: border-box;
  }

  /* --- 基本レイアウト（PC: 971px以上） --- */
  .category-container { 
    max-width: 1000px; 
    width: 100%;
    margin: 0 auto; 
    padding: 160px 1.5rem 4rem; 
  }

  .category-header { text-align: center;  margin-top: -1rem; margin-bottom: 3rem; }
  .category-header .label { 
    display: inline-block; 
    color: #4a7c59; 
    font-weight: bold; 
    font-size: 0.8rem; 
    text-transform: uppercase; 
    letter-spacing: 0.2em; 
    border-bottom: 2px solid #4a7c59; 
    margin-bottom: 0.5rem; 
  }
  .category-header h1 { font-size: 2.2rem; margin: 0.5rem 0; color: #333; font-weight: 700; }
  .category-header p { color: #666; font-size: 0.9rem; }

  /* グリッド設定 */
  .post-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
    gap: 2.5rem 1.5rem; 
    width: 100%;
  }

  /* カードデザイン */
  .post-card { 
    text-decoration: none; 
    color: inherit; 
    display: flex; 
    flex-direction: column; 
    width: 100%;
    transition: opacity 0.3s ease;
  }
  .post-card:hover { opacity: 0.8; }

  .card-thumb-wrap { 
    position: relative; 
    width: 100%; 
    aspect-ratio: 16 / 9; 
    border-radius: 8px; 
    overflow: hidden; 
    margin-bottom: 1rem; 
    background: #eee; 
  }

  .post-card img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    display: block;
  }

  .card-badge { 
    position: absolute; 
    top: 10px; 
    left: 10px; 
    background: rgba(47, 93, 58, 0.9); 
    color: #fff; 
    font-size: 0.7rem; 
    padding: 3px 8px; 
    border-radius: 4px; 
    font-weight: 500; 
    z-index: 1; 
  }

  .post-info time { display: block; font-size: 0.75rem; color: #888; margin-bottom: 0.5rem; }
  .post-info h2 { 
    font-size: 1.05rem; 
    margin: 0; 
    line-height: 1.5; 
    font-weight: 600; 
    color: #333; 
    display: -webkit-box; 
    -webkit-line-clamp: 3; 
    -webkit-box-orient: vertical; 
    overflow: hidden; 
  }

  /* --- スマホ・タブレット対応（970px以下） --- */
  @media (max-width: 970px) {
    .category-container { 
      padding-top: 120px; 
      padding-bottom: 3rem;
      padding-left: 1.25rem; 
      padding-right: 1.25rem;
    }
    
    .category-header { margin-bottom: 2rem; }
    .category-header h1 { font-size: 1.8rem; }
    
    .post-grid { 
      grid-template-columns: 1fr; 
      max-width: 600px; /* 1列の時に広がりすぎないよう制限 */
      margin: 0 auto; 
      gap: 2rem;
    }

    .post-info h2 {
      font-size: 1.1rem; 
    }
  }

  /* 非常に小さい画面（480px以下） --- */
  @media (max-width: 480px) {
    .category-container { 
      padding-top: 100px;
      padding-left: 1rem;
      padding-right: 1rem;
    }
    .category-header h1 { font-size: 1.5rem; }
    .post-grid { 
      gap: 1.8rem;
    }
  }
</style>