---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import HeaderArticle from '../components/HeaderArticle.astro';
import Footer from '../components/Footer.astro';
import FooterMenu from '../components/FooterMenu.astro';
import { FaChevronRight, FaRegFolderOpen, FaRegFileLines, FaChevronLeft } from "react-icons/fa6";

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const getCategoryId = (cat: any) => {
  if (typeof cat === 'object' && cat !== null) {
    return (cat as any).id || cat.toString();
  }
  return cat;
};

const categoryGroups = [
  {
    groupName: 'アウトドア',
    items: [
      { name: 'キャンプ場', slug: 'campsite' },
      { name: 'キャンプギア', slug: 'campgear' },
      { name: 'アウトドア全般', slug: 'outdoor' }
    ]
  },
  {
    groupName: '雑記',
    items: [
      { name: '旅行', slug: 'travel' },
      { name: 'グルメ', slug: 'gourmet' },
      { name: '雑記全般', slug: 'miscellaneous' }
    ]
  }
];

const displayTitle = "サイトマップ";
---

<html lang="ja">
  <head>
    <BaseHead title={`${displayTitle} - Andes Life`} description="Andes Life の全記事一覧ページです。" />
  </head>
  <body>
    <HeaderArticle />

    <main class="sitemap-container">
      <header class="sitemap-header">
        <h1>{displayTitle}</h1>
      </header>

      <div class="sitemap-content">
        <section class="sitemap-section">
          <h2><FaRegFolderOpen /> サイト案内</h2>
          <ul class="page-list">
            <li><a href="/"><FaChevronRight size={12} /> ホーム</a></li>
            <li><a href="/blog"><FaChevronRight size={12} /> 全記事一覧</a></li>
            <li><a href="/contact"><FaChevronRight size={12} /> お問い合わせ</a></li>
            <li><a href="/privacy-policy"><FaChevronRight size={12} /> プライバシーポリシー</a></li>
          </ul>
        </section>

        {categoryGroups.map((group) => (
          <section class="sitemap-section">
            <h2><FaRegFolderOpen /> {group.groupName}</h2>
            <div class="category-grid">
              {group.items.map((item) => {
                const subPosts = allPosts.filter(post => getCategoryId(post.data.category) === item.slug);
                return subPosts.length > 0 ? (
                  <div class="sub-category-block">
                    <h3>{item.name}</h3>
                    <ul>
                      {subPosts.map(post => (
                        <li>
                          <a href={`/${post.id}/`}>
                            <FaRegFileLines size={14} className="file-icon" /> 
                            <span>{post.data.title}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ) : null;
              })}
            </div>
          </section>
        ))}
      </div>

      <div class="back-to-top">
        <a href="/" class="back-btn">
          <FaChevronLeft size={14} />
          トップページへ戻る
        </a>
      </div>
    </main>

    <Footer />
    <FooterMenu />
  </body>
</html>

<style>
  /* 全体コンテナ */
  .sitemap-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 160px 1.5rem 5rem;
    width: 100%;
    box-sizing: border-box;
    overflow-x: hidden; /* 横揺れ防止 */
  }

  .sitemap-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .sitemap-header h1 {
    font-size: 2.2rem;
    color: #333;
    font-weight: 800;
  }

  .sitemap-section {
    margin-bottom: 4rem;
  }

  .sitemap-section h2 {
    font-size: 1.4rem;
    color: #29a48a;
    border-bottom: 2px solid #29a48a;
    padding-bottom: 0.6rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .sitemap-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sitemap-section li {
    margin-bottom: 1rem;
    width: 100%;
  }

  /* --- ここが一番重要 --- */
  .sitemap-section a {
    color: #444;
    text-decoration: none;
    display: flex; /* 横並び */
    align-items: flex-start; /* アイコンを上揃えに */
    gap: 10px;
    font-size: 0.95rem;
    transition: color 0.2s;
    
    width: 100%;
    min-width: 0; /* これがないと文字が突き抜ける */
  }

  /* アイコンが潰れないように固定 */
  :global(.file-icon) {
    flex-shrink: 0;
    margin-top: 4px;
    color: #999;
  }

  .sitemap-section a:hover {
    color: #29a48a;
    text-decoration: underline;
  }

  .sub-category-block {
    margin-bottom: 2.5rem;
  }

  .sub-category-block h3 {
    font-size: 1.1rem;
    color: #333;
    margin-bottom: 1.2rem;
    background: #f0fdfa;
    display: inline-block;
    padding: 4px 12px;
    border-radius: 4px;
    border-left: 4px solid #29a48a;
  }

  /* 戻るボタン */
  .back-to-top {
    margin-top: 5rem;
    text-align: center;
    border-top: 1px solid #eee;
    padding-top: 3rem;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0.8rem 2rem;
    background: #29a48a;
    color: #fff !important;
    text-decoration: none !important;
    border-radius: 50px;
    font-weight: 600;
    transition: 0.3s;
    width: auto;
    max-width: 100%;
  }

  .back-btn:hover {
    background: #228b75;
    transform: translateY(-2px);
  }

  /* --- スマホレスポンシブ --- */
  @media (max-width: 768px) {
    .sitemap-container {
      padding: 100px 1.2rem 4rem;
    }
    .sitemap-header {
      margin-bottom: 2.5rem;
    }
    .sitemap-header h1 {
      font-size: 1.6rem;
    }
    .sitemap-section h2 {
      font-size: 1.2rem;
    }
    .sitemap-section a {
      font-size: 0.9rem; /* スマホで文字がデカすぎないように微調整 */
    }
    .sub-category-block {
      padding-left: 0;
    }

  }
</style>