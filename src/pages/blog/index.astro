---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import HeaderArticle from '../../components/HeaderArticle.astro';
import Footer from '../../components/Footer.astro';
import FooterMenu from '../../components/FooterMenu.astro';

// React Icons
import { FaClock } from "react-icons/fa6";
import { HiOutlineSquares2X2, HiOutlineListBullet } from "react-icons/hi2";

// 1. 全記事を取得して日付順にソート
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 2. カテゴリー名の表示用マップ
const subCategoryMap: Record<string, string> = {
  "campsite": "キャンプ場",
  "campgear": "キャンプギア",
  "outdoor": "アウトドア",
  "miscellaneous": "雑記",
  "gourmet": "グルメ",
  "travel": "旅行",
};

const displayTitle = "すべての記事一覧";
---

<html lang="ja">
  <head>
    <BaseHead title={displayTitle} description="Andes Lifeのすべての記事を新着順に掲載しています。" />
  </head>
  <body>
    <HeaderArticle />

    <main class="category-container">
      <header class="category-header">
        <span class="label">All Posts</span>
        <h1>{displayTitle}</h1>
        <div class="count-badge">全 {posts.length} 件の記事があります</div>
      </header>

      <div class="view-switch-control">
        <button id="view-card" class="view-btn active" aria-label="カード表示">
          <HiOutlineSquares2X2 size="20" />
        </button>
        <button id="view-list" class="view-btn" aria-label="リスト表示">
          <HiOutlineListBullet size="20" />
        </button>
      </div>

      <div class="grid-wrapper">
        <div class="post-grid" id="postGrid">
          {posts.map((post) => {
            const rawCat = post.data.category;
            const catStr = (typeof rawCat === 'object' && rawCat !== null) ? (rawCat as any).id || rawCat.toString() : rawCat;
            const subCatName = subCategoryMap[catStr] || catStr;

            return (
              <a href={`/${post.id}/`} class="post-card">
                <div class="card-thumb-wrap">
                  {post.data.heroImage ? (
                    <img src={post.data.heroImage.src} alt="" />
                  ) : (
                    <div class="no-image">No Image</div>
                  )}
                  <span class="card-badge">{subCatName}</span>
                </div>
                <div class="post-info">
                  <time>
                    <FaClock size={12} style={{marginRight: '4px', display: 'inline-block', verticalAlign: 'middle'}} /> 
                    {post.data.pubDate.toLocaleDateString('ja-JP')}
                  </time>
                  <h2>{post.data.title}</h2>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </main>

    <Footer />
    <FooterMenu />

    <script>
      const setupViewSwitch = () => {
        const grid = document.getElementById('postGrid');
        const btnCard = document.getElementById('view-card');
        const btnList = document.getElementById('view-list');

        if (!grid || !btnCard || !btnList) return;

        let isAnimating = false;

        const switchView = (isList: boolean) => {
          if (isAnimating) return;
          isAnimating = true;

          // 1. 下へフェードアウト
          grid.classList.add('view-exit');
          
          setTimeout(() => {
            // 2. 完全に隠れた瞬間にレイアウトを切り替え
            if (isList) {
              grid.classList.add('is-list-view');
              btnList.classList.add('active');
              btnCard.classList.remove('active');
            } else {
              grid.classList.remove('is-list-view');
              btnCard.classList.add('active');
              btnList.classList.remove('active');
            }
            
            // 3. クラスを入れ替えて下からフェードイン
            grid.classList.remove('view-exit');
            grid.classList.add('view-enter');
            
            setTimeout(() => {
              grid.classList.remove('view-enter');
              isAnimating = false;
            }, 300);
          }, 250);
        };

        btnCard.addEventListener('click', () => {
          if (!grid.classList.contains('is-list-view')) return;
          switchView(false);
        });

        btnList.addEventListener('click', () => {
          if (grid.classList.contains('is-list-view')) return;
          switchView(true);
        });
      };

      document.addEventListener("DOMContentLoaded", setupViewSwitch);
      document.addEventListener("astro:page-load", setupViewSwitch);
    </script>
  </body>
</html>

<style>
  * { box-sizing: border-box; }

  .category-container { 
    max-width: 1000px; 
    width: 100%;
    margin: 0 auto; 
    padding: 160px 1.5rem 4rem; 
  }

  /* --- ヘッダー --- */
  .category-header { text-align: center; margin-bottom: 2rem; }
  .category-header .label { 
    display: inline-block; 
    color: #4a7c59; 
    font-weight: bold; 
    font-size: 0.8rem; 
    text-transform: uppercase; 
    letter-spacing: 0.2em; 
    border-bottom: 2px solid #4a7c59; 
    margin-bottom: 0.8rem; 
    line-height: 1.8;
  }
  .category-header h1 { font-size: 2.2rem; margin: 0; color: #333; font-weight: 700; }
  .category-header .count-badge { color: #646464; font-size: 0.9rem; margin-top: 1.0rem; }

  /* --- 切り替えボタン --- */
  .view-switch-control {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-bottom: 2rem;
  }
  .view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 8px;
    color: #aaa;
    cursor: pointer;
    transition: 0.2s;
  }
  .view-btn.active {
    background: #4a7c59;
    color: #fff;
    border-color: #4a7c59;
  }

  /* --- アニメーション --- */
  .grid-wrapper { position: relative; overflow: hidden; }
  .post-grid { 
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.25s ease, transform 0.25s ease;
    will-change: opacity, transform;
  }
  .view-exit { opacity: 0; transform: translateY(20px); }
  .view-enter { animation: slideUp 0.3s ease-out forwards; }
  @keyframes slideUp {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* --- グリッド（カード型） --- */
  .post-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
    gap: 2.5rem 1.5rem; 
  }
  .post-card { text-decoration: none; color: inherit; display: flex; flex-direction: column; transition: opacity 0.3s; }
  .post-card:hover { opacity: 0.8; }
  .card-thumb-wrap { position: relative; aspect-ratio: 16 / 9; border-radius: 8px; overflow: hidden; margin-bottom: 1rem; background: #eee; }
  .post-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card-badge { position: absolute; top: 10px; left: 10px; background: rgba(47, 93, 58, 0.9); color: #fff; font-size: 0.7rem; padding: 3px 10px; border-radius: 4px; z-index: 1; }
  .post-info time { display: block; font-size: 0.75rem; color: #888; margin-bottom: 0.5rem; }
  .post-info h2 { font-size: 1.05rem; margin: 0; line-height: 1.5; font-weight: 600; color: #333; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  /* --- リスト表示 --- */
  .post-grid.is-list-view { display: flex; flex-direction: column; gap: 1rem; }
  .post-grid.is-list-view .post-card { flex-direction: row; align-items: center; gap: 1.5rem; border-bottom: 1px solid #f2f2f2; padding-bottom: 1rem; }
  .post-grid.is-list-view .card-thumb-wrap { width: 180px; height: 101px; margin-bottom: 0; flex-shrink: 0; border-radius: 6px; }
  .post-grid.is-list-view .card-badge { top: 5px; left: 5px; font-size: 0.6rem; padding: 1px 6px; }

  /* --- スマホ対応 --- */
  @media (max-width: 970px) {
    .category-container { padding-top: 120px; }
    .post-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; gap: 3.5rem; }
    .post-grid.is-list-view .card-thumb-wrap { width: 120px; height: 80px; }
  }
</style>