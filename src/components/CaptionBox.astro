---
const { title = "キャプション" } = Astro.props;
---

<div class="caption-box">
  <div class="caption-label">{title}</div>

  <div class="caption-body">
    <slot />
  </div>
</div>

<style>
.caption-box {
  border: 2px solid #33bfa1;
  background: #fcfffc;
  border-radius: 6px;
  padding: 1rem;
  margin: 2.5rem 0;
  position: relative;
}

/* 左上のラベル */
.caption-label {
  position: absolute;
  top: -12px;
  left: 12px;
  background: #33bfa1;
  color: #fff;
  padding: 2px 10px;
  font-size: 0.8rem;
  border-radius: 4px;
  font-weight: 400;
}
.caption-label:empty {
  display: none;
}

/* 本文（Markdown対応） */
.caption-body {
  margin-top: 15px;
  color: #222;
  line-height: 1.6;
}

/* リスト対応 */
.caption-body ul,
.caption-body ol {
  margin: 0.4rem 0 0 1.2rem;
}

.caption-body li {
  margin-bottom: 0.3rem;
}

/* 改行対応（Markdownの改行も反映） */
.caption-body p {
  white-space: pre-line;
}
</style>