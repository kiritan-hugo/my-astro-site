---
const { items = [], note = "" } = Astro.props;
---

<div class="info-table">
  <dl>
    {items.map(item => (
      <div class="row">
        <dt>{item.label}</dt>
        <dd set:html={item.value}></dd>
      </div>
    ))}
  </dl>
</div>

{note && (
  <div class="info-note" set:html={note}></div>
)}

<style>
.info-table {
  background: #f9f9f9;
  padding: 0rem 0rem;
  border-radius: 6px;
  border: 1px solid #eee;
  margin: 1.5rem 0 0.5rem 0;
}

.info-table dl {
  margin: 0;
}

.info-table .row {
  display: grid;
  grid-template-columns: 140px 1fr;
  padding: 0;
  border-bottom: 1px solid #eee;
}

.info-table dt {
  padding: 0.6rem 0.6rem;
  font-weight: 600;
  color: #2f5d3a;
  white-space: pre-line;
}

.info-table dd {
  margin: 0;
  padding: 0.6rem 0.8rem;
  background: #fff;
  word-break: break-all; /* これでURLも枠内で折り返します */
  overflow-wrap: break-word;
  min-width: 0; /* grid内での突き抜け防止 */
}

.info-table dd :global(a) {
  color: #4a7c59;
  text-decoration: underline;
  word-break: break-all;
}

/* 注釈（テーブル外・背景なし・中央寄せ） */
.info-note {
  margin-top: 0.5rem;
  text-align: center;
  font-size: 0.8rem;
  color: #555;
  padding-bottom: 2rem;
}

/* ▼▼ スマホ用対応 (970px以下) ▼▼ */
@media (max-width: 970px) {
  .info-table .row {
    /* 横並びをやめて、上下に並べる */
    grid-template-columns: 1fr;
  }

  .info-table dt {
    padding: 0.5rem 0.8rem 0.2rem;
    font-size: 0.95rem;
    background: #fdfdfd; /* ラベル側に少し色を付けると見やすい */
  }

  .info-table dd {
    padding: 0.2rem 0.8rem 0.6rem;
    font-size: 0.9rem;
    border-radius: 0; /* 横並びじゃないので角丸は不要 */
  }
}

  .info-note {
  margin-top: 0.5rem;
  font-size: 0.65rem;
  color: #555;
  padding-bottom: 2rem;
}

</style>