---
import { FaTwitter, FaGithub } from "react-icons/fa6";
const today = new Date();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <h2 class="footer-logo">Andes Life</h2>
      <p class="footer-desc">
        アウトドア・キャンプを中心に、自然の魅力を発信するブログ。
      </p>
    </div>

    <nav class="footer-nav">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
      <a href="/privacy-policy">Privacy Policy</a>
    </nav>

    <div class="footer-bottom">
      <div class="social-links">
        <a href="https://twitter.com/あなたのID" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
          <FaTwitter size={20} />
        </a>
        <a href="https://github.com/あなたのID" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <FaGithub size={20} />
        </a>
      </div>
      <p class="footer-copy">&copy; {today.getFullYear()} AndesLife. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 3.0rem;
    /* 上下のパディングを抑えてスリムに */
    padding: 2.5rem 1rem 1.5rem;
    background: #f8f9fa;
    color: #444;
    border-top: 1px solid #eee;
  }

  .footer-inner {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-top {
    margin-bottom: 1rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 800;
    margin-bottom: 0.2rem;
    color: #333;
    letter-spacing: 0.01em;
  }

  .footer-desc {
    font-size: 0.85rem;
    color: #777;
    margin: 0;
  }

  .footer-nav {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .footer-nav a {
    color: #555;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.85rem;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: #29a48a;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    border-top: 1px solid #eee;
    padding-top: 1.2rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .social-links a {
    color: #888;
    transition: color 0.2s, transform 0.2s;
  }

  .social-links a:hover {
    color: #333;
    transform: translateY(-2px);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #aaa;
    margin: 0;
    letter-spacing: 0.03em;
  }

  @media (max-width: 480px) {
    .footer-nav {
      gap: 0.8rem;
    }
    .footer-nav a {
      font-size: 0.8rem;
    }
  }
</style>