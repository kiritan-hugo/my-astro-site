---
import { Image } from "astro:assets";

const {
  step = 1,
  title = "",
  text = "",
  images = [],
  caption = "",
  imagewidth = "100%",
  children
} = Astro.props;

const validImages = images.filter(
  img => img && typeof img === "object" && typeof img.src === "string" && img.src.length > 0
);
---
<div class="step-item">
  <div class="step-content">

    <div class="step-header">
      <div class="step-tag">STEP {step}</div>
      <div class="step-title">{title}</div>
    </div>

    <p class="step-text">{text}</p>

    {validImages.length > 0 && (
      <div class="step-images">
        {validImages.map(img => (
          <div class="step-image-wrap">
            <Image
              src={img}
              alt=""
              class="step-image"
              style={{ width: imagewidth }}
            />
          </div>
        ))}
        {caption && <div class="step-caption">{caption}</div>}
      </div>
    )}
    {children}
  </div>
</div>

<style>
/* --- 全体のはみ出し防止 --- */
* {
  box-sizing: border-box;
}

.step-item {
  margin: 1.6rem 0;
  width: 100%;
}

.step-content {
  background: #f4faf8;
  padding: 1rem 1.2rem;
  border-radius: 10px;
  border: 1px solid #dcebe7;
}

.step-header {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.6rem;
}

.step-tag {
  background: #59b29f;
  color: white;
  padding: 0.2rem 0.6rem;
  border-radius: 6px 6px 6px 0;
  font-size: 0.8rem;
  font-weight: 600;
  white-space: nowrap;
}

.step-title {
  margin: 0;
  font-size: 1.25rem;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
}

.step-text {
  margin: 0;
  line-height: 1.7;
  color: #444;
  white-space: pre-line;
}

.step-images {
  margin-top: 1rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: center; /* 中央寄せ */
}

.step-image-wrap {
  width: 100%; /* 基本は幅いっぱい */
  text-align: center;
}

/* Astro の <Image /> が生成する img */
.step-image-wrap :global(img) {
  border-radius: 8px; /* 少し角丸にすると馴染みます */
  max-width: 100%;
  height: auto;
  display: block;
  margin: 0 auto;
}

.step-caption {
  margin-top: -0.5rem;
  font-size: 0.85rem;
  color: #6a7f78;
  text-align: center;
}

/* --- スマホ・タブレット対応（970px以下） --- */
@media (max-width: 970px) {
  .step-content {
    padding: 1rem 0.8rem; /* 余白を少し詰める */
  }

  /* タイトルを少し小さく、詰まりすぎないように */
  .step-title {
    font-size: 1.05rem;
    line-height: 1.3;
  }

  /* 画像を「小さめ」にさせない設定 */
  .step-image-wrap :global(img) {
    /* props で指定された width をスマホでは 100% に上書き */
    width: 100% !important; 
    max-width: 100% !important;
  }
  
  .step-tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
  }
}
</style>