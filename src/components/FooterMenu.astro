---
/* FooterMenu.astro */
import { FaListUl, FaHouse, FaTent, FaPenNib, FaChevronUp } from "react-icons/fa6";
---

<nav class="mobile-footer-menu" id="mobileFooterMenu">
  <ul class="menu-list">
    <li>
      <button onclick="document.getElementById('mobileTocOverlay')?.classList.add('is-active')">
        <FaListUl className="icon" />
        <span>目次</span>
      </button>
    </li>
    <li>
      <a href="/">
        <FaHouse className="icon" />
        <span>ホーム</span>
      </a>
    </li>
    <li>
      <a href="/category/outdoor">
        <FaTent className="icon" />
        <span>キャンプ</span>
      </a>
    </li>
    <li>
      <a href="/category/miscellaneous">
        <FaPenNib className="icon" />
        <span>雑記</span>
      </a>
    </li>
    <li>
      <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
        <FaChevronUp className="icon icon-3d" />
        <span>トップへ</span>
      </button>
    </li>
  </ul>
</nav>

<script>
  const setupFooterMenu = () => {
    let lastScrollY = window.scrollY;
    const footerMenu = document.getElementById('mobileFooterMenu');
    const showThreshold = 300; 

    if (!footerMenu) return;

    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      if (currentScrollY < showThreshold) {
        footerMenu.classList.remove('is-active');
        lastScrollY = currentScrollY;
        return;
      }
      if (Math.abs(currentScrollY - lastScrollY) > 5) {
        if (currentScrollY > lastScrollY) {
          footerMenu.classList.add('is-active');
        } else {
          footerMenu.classList.remove('is-active');
        }
      }
      lastScrollY = currentScrollY;
    });
  };

  document.addEventListener('DOMContentLoaded', setupFooterMenu);
  document.addEventListener('astro:page-load', setupFooterMenu);
</script>

<style>
  .mobile-footer-menu {
    display: none;
  }

  @media (max-width: 970px) {
    .mobile-footer-menu {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      border-top: 1px solid rgba(0, 0, 0, 0.05);
      z-index: 9999;
      transform: translateY(100%);
      transition: transform 0.3s ease-out;
      height: auto;
    }

    .mobile-footer-menu.is-active {
      transform: translateY(0);
    }

    .menu-list {
      display: flex;
      justify-content: space-around;
      align-items: center;
      margin: 0;
      padding: 5px 0 calc(5px + env(safe-area-inset-bottom, 0px));
      list-style: none;
      /* 3Dの奥行きを設定（数値が小さいほど歪みが強くなります） */
      perspective: 400px;
    }

    .menu-list li {
      flex: 1;
    }

    .menu-list a, 
    .menu-list button {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      background: none;
      border: none;
      color: #29a48a; 
      width: 100%;
      cursor: pointer;
      padding: 2px 0; 
      font-family: inherit;
      -webkit-tap-highlight-color: transparent;
    }

    .icon {
      font-size: 1.15rem;
      margin-bottom: 5px;
    }

    .menu-list span {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.0;
    }

    /* --- 3D回転アニメーション --- */
    @keyframes rotate3d {
      0% { transform: rotateY(0deg); }
      20% { transform: rotateY(360deg); } /* 素早く1回転 */
      100% { transform: rotateY(360deg); } /* 残りの時間は静止 */
    }

    .icon-3d {
      display: inline-block;
      /* 4秒に1回、くるっと回る設定 */
      animation: rotate3d 4s infinite ease-in-out;
      /* 回転時、裏面を綺麗に見せるための設定 */
      transform-style: preserve-3d;
    }

    /* タップした時に少しだけ小さくするリアクション */
    .menu-list button:active .icon {
      transform: scale(0.9);
      transition: 0.1s;
    }
  }
</style>