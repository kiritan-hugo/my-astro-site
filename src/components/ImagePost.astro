---
import { Image } from "astro:assets";

interface Props {
  src: any;
  alt?: string;
  label?: string;
  labelPosition?: "top-left" | "top-right" | "bottom-left" | "bottom-right";
  scale?: number;
  caption?: string;
  captionUrl?: string;
}

const {
  src,
  alt = "",
  label = "",
  labelPosition = "top-left",
  scale = 1,
  caption = "",
  captionUrl = "",
} = Astro.props;

const positionClass = {
  "top-left": "label-top-left",
  "top-right": "label-top-right",
  "bottom-left": "label-bottom-left",
  "bottom-right": "label-bottom-right",
}[labelPosition];
---

<div class="image-wrapper" style={`--image-scale: ${scale};`}>
  {label && <div class={`image-label ${positionClass}`}>{label}</div>}

  <div class="image-frame">
    <Image src={src} alt={alt} />
  </div>

  {caption && (
    captionUrl ? (
      <a href={captionUrl} class="image-caption" target="_blank" rel="noopener">
        {caption}
      </a>
    ) : (
      <p class="image-caption">{caption}</p>
    )
  )}
</div>

<style>
.image-wrapper {
  position: relative;
  display: block;
  width: fit-content;
  max-width: 100%; /* 親要素からはみ出さないように */
  margin: 4rem auto 2rem;
  transform: scale(var(--image-scale));
  transform-origin: center top;
}

/* ラベル */
.image-label {
  position: absolute;
  background: #fff;
  padding: 13px 16px;
  border-radius: 6px;
  font-size: 1.05rem;
  font-weight: 500;
  line-height: 1.4;
  letter-spacing: 0.02em;
  box-shadow: 0 6px 22px rgba(0, 0, 0, 0.18);
  z-index: 2;
  white-space: nowrap;
  border: 2px solid #d8cfbd;
}

.label-top-left { top: -40px; left: -24px; }
.label-top-right { top: -40px; right: -24px; }
.label-bottom-left { bottom: -40px; left: -24px; }
.label-bottom-right { bottom: -40px; right: -24px; }

/* 白枠 */
.image-frame {
  padding: 24px;
  background: #fff;
  border-radius: 0;
  box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

.image-frame :global(img) {
  display: block;
  width: 100%;
  height: auto;
}

.image-caption {
  text-align: center;
  font-size: 0.75rem;
  color: #555;
  margin-top: 0.8rem;
  line-height: 1.4;
  display: block;
  text-decoration: none;
}

/* ▼ 970px以下（レスポンシブ対応） */
@media (max-width: 970px) {
  .image-wrapper {
    /* スマホではScaleを無効化するか、控えめにする（レイアウト崩れ防止） */
    --image-scale: 1 !important; 
    width: 100%; 
    margin: 4rem auto 1.5rem;
  }

  .image-frame {
    padding: 12px; /* 白枠を細くして画像を大きく見せる */
  }

  .image-label {
    padding: 6px 12px;
    font-size: 0.9rem;
  }

  /* ラベルの飛び出しを抑える */
  .label-top-left { top: -30px; left: 0px; }
  .label-top-right { top: -30px; right: 0px; }
  .label-bottom-left { bottom: -25px; left: 5px; }
  .label-bottom-right { bottom: -25px; right: 5px; }

  .image-caption {
    font-size: 0.7rem;
    padding: 0 10px;
  }
}
</style>