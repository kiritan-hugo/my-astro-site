---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
// react-icons から必要なアイコンをインポート
import { 
  FaHouse, 
  FaTent, 
  FaBookOpen, 
  FaEnvelope, 
  FaFeatherPointed, 
  FaBars, 
  FaXmark 
} from "react-icons/fa6";
---

<header class="site-header">
  <div class="header-pc">
    <div class="logo">
      <img src="/images/logos/header_skl.png" alt="Andes Life ロゴ">
    </div>

    <nav class="nav-menu">
      <a href="/">
        <span class="label"><FaHouse size={14} />ホーム</span>
        <span class="en">HOME</span>
      </a>

      <div class="nav-item-has-children">
        <a href="/category/outdoor">
          <span class="label"><FaTent size={14} />アウトドア</span>
          <span class="en">OUTDOOR</span>
        </a>
        <ul class="sub-menu">
          <li><a href="/category/campsite">キャンプ場</a></li>
          <li><a href="/category/campgear">キャンプギア</a></li>
        </ul>
      </div>

      <div class="nav-item-has-children">
        <a href="/category/miscellaneous">    
          <span class="label"><FaBookOpen size={14} />雑記</span>
          <span class="en">NOTE</span>
        </a>
        <ul class="sub-menu">
          <li><a href="/category/travel">旅行</a></li>
          <li><a href="/category/gourmet">グルメ</a></li>
        </ul>
      </div>

      <a href="/contact">
        <span class="label"><FaEnvelope size={14} />お問い合わせ</span>
        <span class="en">INQUIRY</span>
      </a>

      <a href="/sitemap">
        <span class="label"><FaFeatherPointed size={14} />サイトマップ</span>
        <span class="en">SITEMAP</span>
      </a>
    </nav>
  </div>

  <div class="header-sp">
    <button class="hamburger" id="hamburgerBtn">
      <FaBars size={24} />
    </button>
    <div class="sp-logo">
      <img src="/images/logos/header_skl.png" alt="Andes Life ロゴ">
    </div>
  </div>

  <div class="sp-menu" id="spMenu">
    <button class="close-btn" id="closeBtn">
      <FaXmark size={30} />
    </button>
    <nav>
      <a href="/">ホーム</a>
      <div class="sp-nav-group">
        <span class="sp-category-title">アウトドア</span>
        <div class="sp-sub-links">
          <a href="/category/campsite">・キャンプ場</a>
          <a href="/category/campgear">・キャンプギア</a>
        </div>
      </div>
      <div class="sp-nav-group">
        <span class="sp-category-title">雑記</span>
        <div class="sp-sub-links">
          <a href="/category/travel">・旅行</a>
          <a href="/category/gourmet">・グルメ</a>
        </div>
      </div>
      <a href="/contact">お問い合わせ</a>
      <a href="/sitemap">サイトマップ</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("hamburgerBtn");
  const menu = document.getElementById("spMenu");
  const closeBtn = document.getElementById("closeBtn");

  btn?.addEventListener("click", () => menu?.classList.toggle("open"));
  closeBtn?.addEventListener("click", () => menu?.classList.remove("open"));
</script>

<style>
  /* --- 基本設定 --- */
  .logo img { max-width: 100%; height: 45px; }
  .sp-logo img { height: 32px; width: auto; }
  .sp-logo { padding-top: 8px; }

  .site-header {
    position: absolute;
    top: 0;
    width: 100%;
    z-index: 100;
    background: transparent;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
    height: 70px;
  }

  /* --- PC Header --- */
  .header-pc {
    width: 100%;
    padding: 0.8rem 2rem;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 1rem;
  }

  .nav-menu {
    margin-left: auto;
    display: flex;
    gap: 1.8rem;
    align-items: center;
  }

  .nav-menu a {
    position: relative;
    font-size: 0.9rem;
    color: #fff;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.3;
  }

  .nav-menu a .label { display: inline-flex; align-items: center; gap: 6px; }
  .nav-menu a .en { font-size: 0.6rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.05em; }

  .nav-menu a::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -4px;
    width: 0;
    height: 2px;
    background: #fff;
    transition: 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform: translateX(-50%);
  }
  .nav-menu a:hover::after,
  .nav-item-has-children:hover > a::after { width: 100%; }

  /* --- PC サブメニュー --- */
  .nav-item-has-children {
    position: relative;
    padding-bottom: 15px;
    margin-bottom: -15px;
  }

  .sub-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: 160px;
    background: #ffffff;
    border: 2px solid #101010;
    list-style: none;
    padding: 0;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    transition: all 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 6px 6px 0px #101010;
    overflow: hidden;
  }

  .nav-item-has-children:hover .sub-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .sub-menu li { border-bottom: 1px solid #eee; }
  .sub-menu li a {
    color: #101010 !important;
    padding: 0.8rem 1.2rem !important;
    font-size: 0.85rem !important;
    text-align: left;
    display: block !important;
    font-weight: 700;
  }
  .sub-menu li a:hover {
    background-color: #f9f9f9;
    color: #5d6d4e !important;
    padding-left: 1.5rem !important;
  }

  /* --- SP Header (絶対中央配置) --- */
  .header-sp {
    display: none !important;
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hamburger {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
  }

  .sp-logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* --- SP Slide Menu --- */
  .sp-menu {
    position: fixed;
    top: 0; left: -100%;
    width: 80%; height: 100vh;
    background: rgba(18, 20, 18, 0.98);
    padding: 4rem 2rem;
    transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1000;
    overflow-y: auto;
  }
  .sp-menu.open { left: 0; }
  .close-btn { position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: #fff; display: flex; align-items: center; }

  .sp-menu nav { display: flex; flex-direction: column; gap: 1.8rem; }
  .sp-menu a { color: #fff; text-decoration: none; font-size: 1.1rem; font-weight: 500; }

  .sp-nav-group { display: flex; flex-direction: column; gap: 0.8rem; }
  .sp-category-title { font-size: 1.1rem; font-weight: 700; color: #fff; opacity: 0.6; }
  .sp-sub-links { display: flex; flex-direction: column; gap: 0.8rem; padding-left: 1rem; border-left: 1px solid rgba(255,255,255,0.2); }
  .sp-sub-links a { font-size: 0.95rem; color: #ffffff !important; }

  @media (max-width: 1020px) {
    .site-header { height: 55px; }
    .header-pc { display: none !important; }
    .header-sp { display: block !important; }
  }
</style>