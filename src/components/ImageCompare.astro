---
import { Image } from "astro:assets";

const {
  // 1段目
  left,
  right,
  leftLabel = "",
  rightLabel = "",

  // 2段目
  left2 = null,
  right2 = null,
  leftLabel2 = "",
  rightLabel2 = "",

  // 3段目
  left3 = null,
  right3 = null,
  leftLabel3 = "",
  rightLabel3 = "",

  // overlay モード
  overlay = false
} = Astro.props;

const hasSecondRow = left2 && right2;
const hasThirdRow = left3 && right3;
---
<div class="compare-container">

  <!-- 1段目 -->
  <div class="compare-row">
    <div class={`compare-item ${overlay ? "overlay" : ""}`}>
      <Image src={left} alt={leftLabel} />
      {leftLabel && <p class="label">{leftLabel}</p>}
    </div>

    <div class={`compare-item ${overlay ? "overlay" : ""}`}>
      <Image src={right} alt={rightLabel} />
      {rightLabel && <p class="label">{rightLabel}</p>}
    </div>
  </div>

  <!-- 2段目 -->
  {hasSecondRow && (
    <div class="compare-row">
      <div class={`compare-item ${overlay ? "overlay" : ""}`}>
        <Image src={left2} alt={leftLabel2} />
        {leftLabel2 && <p class="label">{leftLabel2}</p>}
      </div>

      <div class={`compare-item ${overlay ? "overlay" : ""}`}>
        <Image src={right2} alt={rightLabel2} />
        {rightLabel2 && <p class="label">{rightLabel2}</p>}
      </div>
    </div>
  )}

  <!-- 3段目 -->
  {hasThirdRow && (
    <div class="compare-row">
      <div class={`compare-item ${overlay ? "overlay" : ""}`}>
        <Image src={left3} alt={leftLabel3} />
        {leftLabel3 && <p class="label">{leftLabel3}</p>}
      </div>

      <div class={`compare-item ${overlay ? "overlay" : ""}`}>
        <Image src={right3} alt={rightLabel3} />
        {rightLabel3 && <p class="label">{rightLabel3}</p>}
      </div>
    </div>
  )}

</div>

<style>
.compare-container {
  display: flex;
  flex-direction: column;
  gap: 1.0rem;
  margin: 1.5rem 0;
}

.compare-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.8rem;
}

.compare-item {
  text-align: center;
  position: relative; /* overlay 用 */
}

/* Astro の <Image /> が生成する img を対象にする */
.compare-item :global(img) {
  height: 260px;       /* ← 高さ揃え（今まで通り） */
  object-fit: cover;   /* ← 縦横比が違っても綺麗に揃う */
  width: 100%;
  display: block;
}

/* 通常キャプション */
.label {
  margin-top: 0.4rem;
  font-size: 0.75rem;
  color: #555;
}

/* overlay モード */
.compare-item.overlay .label {
  position: absolute;
  bottom: 6px;
  left: 50%;
  transform: translateX(-50%);
  margin: 0;
  padding: 2px 8px;
  font-size: 0.75rem;
  color: white;
  background: rgba(0, 0, 0, 0.28);
  border-radius: 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ▼▼ スマホ用対応 (970px以下) ▼▼ */
@media (max-width: 970px) {
  .compare-container {
    gap: 0.5rem; /* 行間の隙間を少し詰める */
    margin: 1rem 0;
  }

  .compare-row {
    gap: 0.4rem; /* 左右の画像同士の隙間を詰める */
  }

  /* 画像の高さ制限を解除、またはスマホ用に低くする */
  .compare-item :global(img) {
    height: 140px;      /* 260pxからスマホ用にダウン */
    border-radius: 4px; /* ついでに角を少し丸くするとスマホっぽくなります */
  }

  /* ラベルの調整 */
  .label {
    font-size: 0.65rem; /* 文字を小さく */
    margin-top: 0.3rem;
  }

  /* overlay モードのラベル調整 */
  .compare-item.overlay .label {
    bottom: 4px;
    padding: 1px 6px;
    font-size: 0.6rem;
    max-width: 90%; /* はみ出し防止 */
  }
}
</style>