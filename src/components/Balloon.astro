---
import { characters } from "../data/characters";

const { person = "kiritan", type = "left" } = Astro.props;
const char = characters[person];
---
<div class={`balloon ${type} ${person}`}>
  <div class="balloon-icon-wrap">
    <img src={char.icon.src} alt={char.name} class="balloon-icon" />
    <div class="balloon-name">{char.name}</div>
  </div>

  <div class="balloon-body">
    <slot />
  </div>
</div>

<script>
  const setupBalloons = () => {
    const balloons = document.querySelectorAll(".balloon-body");

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, {
      threshold: 0.3
    });

    balloons.forEach(b => observer.observe(b));
  };

  document.addEventListener("DOMContentLoaded", setupBalloons);
  document.addEventListener("astro:page-load", setupBalloons);
</script>

<style>
/* 全体レイアウト */
.balloon {
  display: flex;
  /* ★ 調整：アイコンと吹き出しの間の距離を広げる (1.2rem -> 1.8rem) */
  gap: 1.8rem; 
  margin: 2.2rem 0;
  align-items: flex-start; 
}

.balloon.right {
  flex-direction: row-reverse;
}

/* アイコン＋名前 */
.balloon-icon-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.balloon-icon {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 2px 6px rgba(0,0,0,0.15);
}

.balloon-name {
  margin-top: 0.4rem;
  font-size: 0.75rem;
  font-weight: 400;
  color: #333;
}

/* 吹き出し本体 */
.balloon-body {
  padding: 1.0rem 1.0rem;
  border-radius: 10px;
  line-height: 1.7; 
  min-height: 0;
  position: relative;
  max-width: 650px;
  border: 1px solid var(--border-color);
  background: var(--bg-color);
  box-shadow: 0 4px 14px rgba(0,0,0,0.08);
  overflow: visible;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  margin-top: 10px; 
}

.balloon-body :global(p) {
  margin: 0;
}

.balloon-body.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ▼ 三角形の位置：アイコンから離した分、少し調整が必要な場合があります */
.balloon.left .balloon-body::before {
  content: "";
  position: absolute;
  left: -14px;
  top: 15px; 
  width: 14px;
  height: 20px;
  background: var(--border-color);
  clip-path: polygon(0 50%, 100% 0, 100% 100%);
}

.balloon.left .balloon-body::after {
  content: "";
  position: absolute;
  left: -11px;
  top: 16px;
  width: 12px;
  height: 17px;
  background: var(--bg-color);
  clip-path: polygon(0 50%, 100% 0, 100% 100%);
}

.balloon.right .balloon-body::before {
  content: "";
  position: absolute;
  right: -14px;
  top: 15px;
  width: 14px;
  height: 20px;
  background: var(--border-color);
  clip-path: polygon(100% 50%, 0 0, 0 100%);
}

.balloon.right .balloon-body::after {
  content: "";
  position: absolute;
  right: -12px;
  top: 16px;
  width: 13px;
  height: 17px;
  background: var(--bg-color);
  clip-path: polygon(100% 50%, 0 0, 0 100%);
}

/* キャラ別スタイル */
.balloon.kiritan { --border-color: #33bfa1; --bg-color: #ffffff; }
.balloon.sena { --border-color: #33bfa1; --bg-color: #e8fff5; }

/* ▼▼ スマホ用対応 (970px以下) ▼▼ */
@media (max-width: 970px) {
  .balloon {
    /* ★ 調整：スマホでもアイコンとの距離を少し確保 (0.8rem -> 1.2rem) */
    gap: 1.2rem;
    margin: 1.5rem 0;
    padding: 0 3px; 
    box-sizing: border-box;
  }
  .balloon-icon {
    width: 55px;
    height: 55px;
  }
  .balloon-name {
    font-size: 0.65rem;
  }
  .balloon-body {
    padding: 0.8rem 0.8rem;
    font-size: 0.9rem;
    /* アイコンとの距離を広げた分、最大幅を再計算して端の余裕を守る */
    max-width: calc(100% - 120px); 
    margin-top: 5px; 
    line-height: 1.4 ;
  }

  .balloon-body :global(*) {
    line-height: 1.6 !important;
    margin: 0; /* ついでに余計なマージンも消して中央に寄せやすくする */
  }

  .balloon.left .balloon-body::before,
  .balloon.right .balloon-body::before { top: 12px; }
  .balloon.left .balloon-body::after { top: 13px;  left: -12px;}
  .balloon.right .balloon-body::after { top: 13px; }
}
</style>