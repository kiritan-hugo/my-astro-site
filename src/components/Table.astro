---
const { title = "", columns = [], rows = [], note = "" } = Astro.props;
---

<div class="tbl-wrap">
  {title && <div class="tbl-title">{title}</div>}

  <div class="tbl-scroll-container">
    <table class="tbl">
      <thead>
        <tr>
          {columns.map(col => <th>{col}</th>)}
        </tr>
      </thead>

      <tbody>
        {rows.map(row => (
          <tr>
            {row.map(cell => (
              <td set:html={cell}></td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {note && <p class="tbl-note">{note}</p>}
</div>

<style>
/* ▼ 外枠 */
.tbl-wrap {
  margin-top: 3rem;
  margin-bottom: 3rem;
}

/* ▼ タイトル */
.tbl-title {
  font-size: 1.1rem;
  font-weight: 600;
  margin-bottom: 0.8rem;
  color: #333;
  padding: 8px 18px;
  background: #ffffff;
  border: 2px solid #d8d2c6;
  border-radius: 20px;
  display: inline-block;
  box-shadow: 0 2px 0 #efe9dd;
}

/* ▼ 横スクロール用のコンテナ設定 */
.tbl-scroll-container {
  overflow-x: auto; /* 横にはみ出た時にスクロールさせる */
  -webkit-overflow-scrolling: touch; /* iOSでのスクロールを滑らかに */
  border-radius: 8px; /* 角を少し丸く */
}

/* ▼ テーブル本体 */
.tbl {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.95rem;
  min-width: 500px; /* スマホで潰れすぎないよう、最小幅を確保 */
}

/* ▼ セル共通 */
.tbl th,
.tbl td {
  border: 1px solid #d8d2c6;
  padding: 12px 20px;
  text-align: center;
  /* white-space: nowrap;  ← PCでも長い文字があるとはみ出る原因になるので削除推奨 */
}

/* ▼ 1行目ヘッダー */
.tbl thead th {
  background: #efe9dd;
  color: #271d1d;
  font-weight: 600;
  white-space: nowrap; /* ヘッダーだけは一行で見せたいことが多いので残す */
}

/* ▼ 本文 */
.tbl tbody td {
  background: #ffffff;
}

/* ▼ 注釈 */
.tbl-note {
  text-align: center;
  margin-top: 0.5rem;
  margin-bottom: 2rem;
  font-size: 0.8rem;
  color: #555;
}

/* ▼ 970px以下（スマホ・タブレット対応） */
@media (max-width: 970px) {
  .tbl {
    font-size: 0.85rem; /* 文字を少し小さく */
  }
  
  .tbl th,
  .tbl td {
    padding: 10px 12px; /* 余白を詰める */
  }

  .tbl-title {
    font-size: 1rem;
    padding: 6px 14px;
  }
}
</style>